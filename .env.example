# Mediawerkzeug API Keys
# Kopiere diese Datei zu .env und trage deine Keys ein

TMDB_API_KEY="dein_tmdb_key_hier"
TVDB_API_KEY="dein_tvdb_key_hier"

# Optionaler Flask Secret Key zur Absicherung von Sessions
FLASK_SECRET_KEY="generiere_ein_zufaelliges_secret_hier"

# ---------------------------------------------------------------------------
# Kritik-Distributions-Tool
# ---------------------------------------------------------------------------

# X (Twitter) OAuth 2.0 App-Credentials
# Registrierung: https://developer.twitter.com/en/portal/dashboard
# Callback-URL dort eintragen: https://deine-domain.de/api/distribute/oauth/x/callback
X_CLIENT_ID="dein_x_client_id"
X_CLIENT_SECRET="dein_x_client_secret"
X_REDIRECT_URI="http://localhost:5000/api/distribute/oauth/x/callback"

# Mastodon OAuth Callback-URL
# Wird beim ersten Login mit einer Instanz automatisch registriert
MASTODON_REDIRECT_URI="http://localhost:5000/api/distribute/oauth/mastodon/callback"
